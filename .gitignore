cat > .gitignore << EOF
# IDE
.idea/
__pycache__/
*.pyc


# Virtual environment
.venv/
venv/
env/

# Environment variables
.env

# Logs
*.log
EOF


# Дистрибуция
dist/
build/
*.egg-info/
*.egg

# Docker volumes
prometheus_data/data/
grafana_data/
postgres_data/

# Docker логи
*.log

.env
.env.local
.env.production
*.secret
secrets.yml
alertmanager/alertmanager.yml

# ОС
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# Тестовые скрипты
test_alert.py
load_test.py

tmp/
temp/
*.tmp